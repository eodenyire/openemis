<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record model="ir.module.category" id="module_category_all_op_health">
            <field name="name">Health</field>
            <field name="description">Helps you manage student health and medical records.</field>
            <field name="sequence">105</field>
            <field name="parent_id" eval="False"/>
        </record>

        <record id="module_category_openemis_health" model="ir.module.category">
            <field name="name">Health</field>
            <field name="description">Helps you manage student health and medical records.</field>
            <field name="parent_id" ref="openemis_health.module_category_all_op_health"/>
            <field name="sequence">1</field>
        </record>

        <record id="group_health_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_openemis_health"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="implied_ids"
                   eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_health_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_openemis_health"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="implied_ids"
                   eval="[(4, ref('openemis_health.group_health_user'))]"/>
        </record>

        <!-- Managers see all health records -->
        <record model="ir.rule" id="health_record_manager_rule">
            <field name="name">Health Records - Manager Full Access</field>
            <field name="model_id" ref="model_op_student_health"/>
            <field name="groups"
                   eval="[(4, ref('openemis_health.group_health_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <!-- Users (faculty) can only see records for their own students -->
        <record model="ir.rule" id="health_record_user_rule">
            <field name="name">Health Records - User Own Student Access</field>
            <field name="model_id" ref="model_op_student_health"/>
            <field name="groups"
                   eval="[(4, ref('openemis_health.group_health_user'))]"/>
            <field name="domain_force">['|', ('student_id.user_id', '=', user.id), ('student_id.user_id', 'in', user.child_ids.ids)]</field>
        </record>
</odoo>
