<?xml version="1.0" encoding="UTF-8"?>
<odoo>
        <record id="view_op_student_health_list" model="ir.ui.view">
            <field name="name">op.student.health.list</field>
            <field name="model">op.student.health</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <list string="Student Health Records">
                    <field name="student_id"/>
                    <field name="blood_group"/>
                    <field name="height"/>
                    <field name="weight"/>
                    <field name="bmi"/>
                    <field name="last_checkup_date" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_op_student_health_form" model="ir.ui.view">
            <field name="name">op.student.health.form</field>
            <field name="model">op.student.health</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Student Health Record">
                    <header/>
                    <sheet>
                        <field name="active" invisible="1"/>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                                invisible="active == True"/>
                        <group>
                            <group string="Student Information">
                                <field name="student_id"/>
                                <field name="blood_group"/>
                                <field name="last_checkup_date"/>
                            </group>
                            <group string="Physical Measurements">
                                <field name="height"/>
                                <field name="weight"/>
                                <field name="bmi"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Medical Information">
                                <group>
                                    <group string="Medical Conditions">
                                        <field name="medical_condition_ids"
                                               widget="many2many_tags"
                                               nolabel="1"/>
                                    </group>
                                    <group string="Allergies">
                                        <field name="allergies" nolabel="1"/>
                                    </group>
                                </group>
                                <group string="Vaccinations">
                                    <field name="vaccination_ids"
                                           widget="many2many_tags"
                                           nolabel="1"/>
                                </group>
                            </page>
                            <page string="Emergency Contact">
                                <group>
                                    <group string="Emergency Contact">
                                        <field name="emergency_contact_name"/>
                                        <field name="emergency_contact_phone"/>
                                        <field name="emergency_contact_relation"/>
                                    </group>
                                    <group string="Doctor">
                                        <field name="doctor_name"/>
                                        <field name="doctor_phone"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Notes">
                                <field name="notes" nolabel="1"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_op_student_health_search" model="ir.ui.view">
            <field name="name">op.student.health.search</field>
            <field name="model">op.student.health</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <search string="Student Health Records">
                    <field name="student_id"/>
                    <field name="blood_group"/>
                    <field name="medical_condition_ids"/>
                    <field name="vaccination_ids"/>
                    <filter string="Archived" name="inactive"
                            domain="[('active', '=', False)]"/>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_open_op_student_health_view">
            <field name="name">Health Records</field>
            <field name="path">student-health</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">op.student.health</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_op_student_health_search"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_open_op_student_health_view_form">
            <field name="act_window_id" ref="act_open_op_student_health_view"/>
            <field name="sequence" eval="20"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_op_student_health_form"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_open_op_student_health_view_list">
            <field name="act_window_id" ref="act_open_op_student_health_view"/>
            <field name="sequence" eval="10"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_op_student_health_list"/>
        </record>
</odoo>
