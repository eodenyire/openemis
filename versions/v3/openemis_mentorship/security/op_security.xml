<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record model="ir.module.category" id="module_category_mentorship">
        <field name="name">Mentorship</field>
        <field name="description">Student mentorship and career guidance platform.</field>
        <field name="sequence">125</field>
    </record>

    <record id="group_op_mentorship_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_mentorship"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <record id="group_op_mentorship_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_mentorship"/>
        <field name="implied_ids"
               eval="[(4, ref('base.group_user')),
                      (4, ref('openemis_mentorship.group_op_mentorship_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

</odoo>
