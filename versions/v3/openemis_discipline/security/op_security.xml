<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record model="ir.module.category" id="module_category_all_op_discipline">
            <field name="name">Discipline</field>
            <field name="description">Helps you manage student disciplinary records.</field>
            <field name="sequence">101</field>
            <field name="parent_id" eval="False"/>
        </record>

        <record id="module_category_openemis_discipline" model="ir.module.category">
            <field name="name">Discipline</field>
            <field name="description">Helps you manage student disciplinary records.</field>
            <field name="parent_id" ref="openemis_discipline.module_category_all_op_discipline"/>
            <field name="sequence">1</field>
        </record>

        <record id="group_discipline_user" model="res.groups">
            <field name="name">Faculty</field>
            <field name="category_id" ref="module_category_openemis_discipline"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_discipline_manager" model="res.groups">
            <field name="name">Admin / Back-office</field>
            <field name="category_id" ref="module_category_openemis_discipline"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="implied_ids"
                   eval="[(4, ref('openemis_discipline.group_discipline_user'))]"/>
        </record>

        <!-- Faculty sees only discipline records they reported -->
        <record model="ir.rule" id="faculty_discipline_rule">
            <field name="name">Faculty Discipline Records</field>
            <field name="model_id" ref="model_op_discipline"/>
            <field name="groups"
                   eval="[(4, ref('openemis_discipline.group_discipline_user'))]"/>
            <field name="domain_force">[('faculty_id.user_id', '=', user.id)]</field>
        </record>

        <!-- Manager sees all discipline records -->
        <record model="ir.rule" id="back_office_discipline_rule">
            <field name="name">Back Office Discipline Records</field>
            <field name="model_id" ref="model_op_discipline"/>
            <field name="groups"
                   eval="[(4, ref('openemis_discipline.group_discipline_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
</odoo>
