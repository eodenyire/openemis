<?xml version="1.0" encoding="UTF-8"?>
<odoo>
        <record id="view_op_misbehaviour_category_list" model="ir.ui.view">
            <field name="name">op.misbehaviour.category.list</field>
            <field name="model">op.misbehaviour.category</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <list string="Misbehaviour Categories">
                    <field name="name"/>
                    <field name="description" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_op_misbehaviour_category_form" model="ir.ui.view">
            <field name="name">op.misbehaviour.category.form</field>
            <field name="model">op.misbehaviour.category</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Misbehaviour Category">
                    <header/>
                    <sheet>
                        <field name="active" invisible="1"/>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                                invisible="active == True"/>
                        <group>
                            <field name="name"/>
                        </group>
                        <div>
                            <label for="description" string="Description" class="mt32"/>
                            <field name="description" nolabel="1"/>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_op_misbehaviour_category_search" model="ir.ui.view">
            <field name="name">op.misbehaviour.category.search</field>
            <field name="model">op.misbehaviour.category</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <search string="Misbehaviour Category">
                    <field name="name"/>
                    <filter string="Archived" name="inactive"
                            domain="[('active', '=', False)]"/>
                    <newline/>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_open_op_misbehaviour_category_view">
            <field name="name">Misbehaviour Categories</field>
            <field name="path">misbehaviour-category</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">op.misbehaviour.category</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_op_misbehaviour_category_search"/>
            <field name="domain">[]</field>
            <field name="context">{}</field>
        </record>

        <record model="ir.actions.act_window.view" id="act_open_op_misbehaviour_category_view_form">
            <field name="act_window_id" ref="act_open_op_misbehaviour_category_view"/>
            <field name="sequence" eval="20"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_op_misbehaviour_category_form"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_open_op_misbehaviour_category_view_list">
            <field name="act_window_id" ref="act_open_op_misbehaviour_category_view"/>
            <field name="sequence" eval="10"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_op_misbehaviour_category_list"/>
        </record>
</odoo>
