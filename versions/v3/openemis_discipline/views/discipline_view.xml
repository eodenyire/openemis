<?xml version="1.0" encoding="UTF-8"?>
<odoo>
        <record id="view_op_discipline_list" model="ir.ui.view">
            <field name="name">op.discipline.list</field>
            <field name="model">op.discipline</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <list string="Discipline Records">
                    <field name="student_id"/>
                    <field name="date"/>
                    <field name="misbehaviour_category_id"/>
                    <field name="discipline_action_id" optional="hide"/>
                    <field name="faculty_id"/>
                    <field name="state"
                           decoration-info="state == 'reported'"
                           decoration-warning="state == 'under_review'"
                           decoration-success="state == 'resolved'"
                           decoration-danger="state == 'action_taken'"
                           widget="badge"/>
                </list>
            </field>
        </record>

        <record id="view_op_discipline_form" model="ir.ui.view">
            <field name="name">op.discipline.form</field>
            <field name="model">op.discipline</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Discipline Record">
                    <header>
                        <button name="action_review" string="Set Under Review" type="object"
                                class="btn-primary"
                                invisible="state != 'reported'"/>
                        <button name="action_taken" string="Action Taken" type="object"
                                class="btn-primary"
                                invisible="state != 'under_review'"/>
                        <button name="action_resolve" string="Resolve" type="object"
                                class="btn-primary"
                                invisible="state != 'action_taken'"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="reported,under_review,action_taken,resolved"/>
                    </header>
                    <sheet>
                        <field name="active" invisible="1"/>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                                invisible="active == True"/>
                        <group>
                            <group>
                                <field name="student_id"/>
                                <field name="faculty_id"/>
                                <field name="date"/>
                            </group>
                            <group>
                                <field name="misbehaviour_category_id"/>
                                <field name="discipline_action_id"/>
                            </group>
                        </group>
                        <div>
                            <label for="description" string="Description" class="mt32"/>
                            <field name="description" nolabel="1"/>
                        </div>
                        <div>
                            <label for="notes" string="Notes" class="mt16"/>
                            <field name="notes" nolabel="1"/>
                        </div>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_op_discipline_search" model="ir.ui.view">
            <field name="name">op.discipline.search</field>
            <field name="model">op.discipline</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <search string="Discipline Records">
                    <field name="student_id"/>
                    <field name="faculty_id"/>
                    <field name="misbehaviour_category_id"/>
                    <field name="date"/>
                    <filter string="Reported" name="reported"
                            domain="[('state', '=', 'reported')]"/>
                    <filter string="Under Review" name="under_review"
                            domain="[('state', '=', 'under_review')]"/>
                    <filter string="Action Taken" name="action_taken"
                            domain="[('state', '=', 'action_taken')]"/>
                    <filter string="Resolved" name="resolved"
                            domain="[('state', '=', 'resolved')]"/>
                    <separator/>
                    <filter string="Archived" name="inactive"
                            domain="[('active', '=', False)]"/>
                    <group expand="0" string="Group By">
                        <filter string="Student" name="group_student"
                                context="{'group_by': 'student_id'}"/>
                        <filter string="Misbehaviour Category" name="group_category"
                                context="{'group_by': 'misbehaviour_category_id'}"/>
                        <filter string="Status" name="group_state"
                                context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="view_op_discipline_pivot" model="ir.ui.view">
            <field name="name">op.discipline.pivot</field>
            <field name="model">op.discipline</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <pivot string="Discipline Pivot">
                    <field name="student_id" type="row"/>
                    <field name="misbehaviour_category_id" type="col"/>
                </pivot>
            </field>
        </record>

        <record model="ir.ui.view" id="view_op_discipline_graph">
            <field name="name">op.discipline.graph</field>
            <field name="model">op.discipline</field>
            <field name="arch" type="xml">
                <graph string="Discipline Graph View" type="bar">
                    <field name="student_id"/>
                    <field name="misbehaviour_category_id"/>
                </graph>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_open_op_discipline_view">
            <field name="name">Discipline Records</field>
            <field name="path">discipline</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">op.discipline</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">list,form,pivot,graph</field>
            <field name="search_view_id" ref="view_op_discipline_search"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_open_op_discipline_view_form">
            <field name="act_window_id" ref="act_open_op_discipline_view"/>
            <field name="sequence" eval="20"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_op_discipline_form"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_open_op_discipline_view_list">
            <field name="act_window_id" ref="act_open_op_discipline_view"/>
            <field name="sequence" eval="10"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_op_discipline_list"/>
        </record>
</odoo>
