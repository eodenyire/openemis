<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record model="ir.module.category" id="module_category_all_op_event">
            <field name="name">Event</field>
            <field name="description">Helps you manage your institutes school events.</field>
            <field name="sequence">105</field>
            <field name="parent_id" eval="False"/>
        </record>

        <record id="module_category_openemis_event" model="ir.module.category">
            <field name="name">Event</field>
            <field name="description">Helps you manage your institutes school events.</field>
            <field name="parent_id" ref="openemis_event.module_category_all_op_event"/>
            <field name="sequence">1</field>
        </record>

        <record id="group_event_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_openemis_event"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="implied_ids"
                   eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_event_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_openemis_event"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="implied_ids"
                   eval="[(4, ref('openemis_event.group_event_user'))]"/>
        </record>

        <record model="ir.rule" id="event_user_rule">
            <field name="name">Event User Rule</field>
            <field name="model_id" ref="model_op_event"/>
            <field name="groups"
                   eval="[(4, ref('openemis_event.group_event_user'))]"/>
            <field name="domain_force">[(1,'=',1)]</field>
        </record>

        <record model="ir.rule" id="event_manager_rule">
            <field name="name">Event Manager Rule</field>
            <field name="model_id" ref="model_op_event"/>
            <field name="groups"
                   eval="[(4, ref('openemis_event.group_event_manager'))]"/>
            <field name="domain_force">[(1,'=',1)]</field>
        </record>
</odoo>
