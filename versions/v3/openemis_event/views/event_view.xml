<?xml version="1.0" encoding="UTF-8"?>
<odoo>
        <record id="view_op_event_list" model="ir.ui.view">
            <field name="name">op.event.list</field>
            <field name="model">op.event</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <list string="Events"
                      decoration-danger="state == 'cancelled'"
                      decoration-success="state == 'completed'">
                    <field name="name"/>
                    <field name="event_type_id"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <field name="venue" optional="show"/>
                    <field name="organizer_id" optional="show"/>
                    <field name="target_audience"/>
                    <field name="registered_count"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="view_op_event_form" model="ir.ui.view">
            <field name="name">op.event.form</field>
            <field name="model">op.event</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Event">
                    <header>
                        <button name="action_publish"
                                invisible="state != 'draft'"
                                type="object"
                                string="Publish"
                                class="oe_highlight"/>
                        <button name="action_start"
                                invisible="state != 'published'"
                                type="object"
                                string="Start Event"
                                class="oe_highlight"/>
                        <button name="action_complete"
                                invisible="state != 'ongoing'"
                                type="object"
                                string="Complete"
                                class="oe_highlight"/>
                        <button name="action_cancel"
                                invisible="state not in ('draft', 'published', 'ongoing')"
                                type="object"
                                string="Cancel"/>
                        <button name="action_reset_draft"
                                invisible="state != 'cancelled'"
                                type="object"
                                string="Reset to Draft"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,published,ongoing,completed"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button"
                                    name="action_open_registrations"
                                    type="object"
                                    icon="fa-users">
                                <field string="Registrations"
                                       name="registered_count"
                                       widget="statinfo"/>
                            </button>
                        </div>
                        <field name="active" invisible="1"/>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                                invisible="active == True"/>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Event Name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="event_type_id"/>
                                <field name="start_date"/>
                                <field name="end_date"/>
                                <field name="venue"/>
                            </group>
                            <group>
                                <field name="organizer_id"/>
                                <field name="target_audience"/>
                                <field name="max_attendees"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="description" string="Description">
                                <field name="description" nolabel="1"/>
                            </page>
                            <page name="registrations" string="Registrations">
                                <field name="registration_ids">
                                    <list editable="top">
                                        <field name="student_id"/>
                                        <field name="faculty_id"/>
                                        <field name="attendee_name"/>
                                        <field name="attendee_email"/>
                                        <field name="registration_date"/>
                                        <field name="attended"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_op_event_kanban" model="ir.ui.view">
            <field name="name">op.event.kanban</field>
            <field name="model">op.event</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <kanban string="Events" default_group_by="state">
                    <field name="name"/>
                    <field name="event_type_id"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <field name="venue"/>
                    <field name="registered_count"/>
                    <field name="state"/>
                    <field name="active"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                    <span class="o_field_widget o_priority"/>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div><field name="event_type_id"/></div>
                                    <div>
                                        <i class="fa fa-calendar"/> <field name="start_date"/>
                                    </div>
                                    <div t-if="record.venue.value">
                                        <i class="fa fa-map-marker"/> <field name="venue"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <span><i class="fa fa-users"/> <field name="registered_count"/> Registrations</span>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="state" widget="label_selection"
                                               options="{'classes': {'draft': 'secondary', 'published': 'info', 'ongoing': 'warning', 'completed': 'success', 'cancelled': 'danger'}}"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="view_op_event_calendar" model="ir.ui.view">
            <field name="name">op.event.calendar</field>
            <field name="model">op.event</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <calendar string="Events"
                          date_start="start_date"
                          date_stop="end_date"
                          color="event_type_id"
                          quick_create="0">
                    <field name="name"/>
                    <field name="venue"/>
                    <field name="state"/>
                </calendar>
            </field>
        </record>

        <record id="view_op_event_search" model="ir.ui.view">
            <field name="name">op.event.search</field>
            <field name="model">op.event</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <search string="Events">
                    <field name="name"/>
                    <field name="event_type_id"/>
                    <field name="organizer_id"/>
                    <field name="venue"/>
                    <separator/>
                    <filter string="Draft" name="draft"
                            domain="[('state', '=', 'draft')]"/>
                    <filter string="Published" name="published"
                            domain="[('state', '=', 'published')]"/>
                    <filter string="Ongoing" name="ongoing"
                            domain="[('state', '=', 'ongoing')]"/>
                    <filter string="Completed" name="completed"
                            domain="[('state', '=', 'completed')]"/>
                    <filter string="Cancelled" name="cancelled"
                            domain="[('state', '=', 'cancelled')]"/>
                    <separator/>
                    <filter string="Archived" name="inactive"
                            domain="[('active', '=', False)]"/>
                    <group expand="0" string="Group By">
                        <filter string="Event Type" name="group_by_type"
                                context="{'group_by': 'event_type_id'}"/>
                        <filter string="State" name="group_by_state"
                                context="{'group_by': 'state'}"/>
                        <filter string="Target Audience" name="group_by_audience"
                                context="{'group_by': 'target_audience'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_open_op_event_view">
            <field name="name">Events</field>
            <field name="path">events</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">op.event</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">list,kanban,calendar,form</field>
            <field name="search_view_id" ref="view_op_event_search"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_open_op_event_view_list">
            <field name="act_window_id" ref="act_open_op_event_view"/>
            <field name="sequence" eval="10"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_op_event_list"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_open_op_event_view_kanban">
            <field name="act_window_id" ref="act_open_op_event_view"/>
            <field name="sequence" eval="20"/>
            <field name="view_mode">kanban</field>
            <field name="view_id" ref="view_op_event_kanban"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_open_op_event_view_calendar">
            <field name="act_window_id" ref="act_open_op_event_view"/>
            <field name="sequence" eval="30"/>
            <field name="view_mode">calendar</field>
            <field name="view_id" ref="view_op_event_calendar"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_open_op_event_view_form">
            <field name="act_window_id" ref="act_open_op_event_view"/>
            <field name="sequence" eval="40"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_op_event_form"/>
        </record>
</odoo>
