<?xml version="1.0" encoding="UTF-8"?>
<odoo>
        <record id="view_op_event_registration_list" model="ir.ui.view">
            <field name="name">op.event.registration.list</field>
            <field name="model">op.event.registration</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <list string="Event Registrations"
                      decoration-danger="state == 'cancelled'"
                      decoration-success="state == 'attended'">
                    <field name="event_id"/>
                    <field name="student_id"/>
                    <field name="faculty_id"/>
                    <field name="attendee_name" optional="show"/>
                    <field name="attendee_email" optional="show"/>
                    <field name="registration_date"/>
                    <field name="attended"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="view_op_event_registration_form" model="ir.ui.view">
            <field name="name">op.event.registration.form</field>
            <field name="model">op.event.registration</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Event Registration">
                    <header>
                        <button name="action_mark_attended"
                                invisible="state != 'registered'"
                                type="object"
                                string="Mark Attended"
                                class="oe_highlight"/>
                        <button name="action_cancel"
                                invisible="state not in ('registered', 'attended')"
                                type="object"
                                string="Cancel"/>
                        <button name="action_reset_registered"
                                invisible="state != 'cancelled'"
                                type="object"
                                string="Reset to Registered"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="registered,attended"/>
                    </header>
                    <sheet>
                        <field name="active" invisible="1"/>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                                invisible="active == True"/>
                        <group>
                            <group>
                                <field name="event_id"/>
                                <field name="student_id"/>
                                <field name="faculty_id"/>
                                <field name="attendee_name"/>
                                <field name="attendee_email"/>
                            </group>
                            <group>
                                <field name="registration_date"/>
                                <field name="attended"/>
                                <field name="state"/>
                            </group>
                        </group>
                        <div>
                            <label for="notes" string="Notes" class="mt32"/>
                            <field name="notes" nolabel="1"/>
                        </div>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_op_event_registration_search" model="ir.ui.view">
            <field name="name">op.event.registration.search</field>
            <field name="model">op.event.registration</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <search string="Event Registrations">
                    <field name="event_id"/>
                    <field name="student_id"/>
                    <field name="faculty_id"/>
                    <field name="attendee_name"/>
                    <separator/>
                    <filter string="Registered" name="registered"
                            domain="[('state', '=', 'registered')]"/>
                    <filter string="Attended" name="attended"
                            domain="[('state', '=', 'attended')]"/>
                    <filter string="Cancelled" name="cancelled"
                            domain="[('state', '=', 'cancelled')]"/>
                    <separator/>
                    <filter string="Archived" name="inactive"
                            domain="[('active', '=', False)]"/>
                    <group expand="0" string="Group By">
                        <filter string="Event" name="group_by_event"
                                context="{'group_by': 'event_id'}"/>
                        <filter string="State" name="group_by_state"
                                context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_open_op_event_registration_view">
            <field name="name">Event Registrations</field>
            <field name="path">event-registrations</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">op.event.registration</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_op_event_registration_search"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_open_op_event_registration_view_list">
            <field name="act_window_id" ref="act_open_op_event_registration_view"/>
            <field name="sequence" eval="10"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_op_event_registration_list"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_open_op_event_registration_view_form">
            <field name="act_window_id" ref="act_open_op_event_registration_view"/>
            <field name="sequence" eval="20"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_op_event_registration_form"/>
        </record>
</odoo>
