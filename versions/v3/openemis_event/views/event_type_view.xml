<?xml version="1.0" encoding="UTF-8"?>
<odoo>
        <record id="view_op_event_type_list" model="ir.ui.view">
            <field name="name">op.event.type.list</field>
            <field name="model">op.event.type</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <list string="Event Types">
                    <field name="name"/>
                    <field name="description"/>
                </list>
            </field>
        </record>

        <record id="view_op_event_type_form" model="ir.ui.view">
            <field name="name">op.event.type.form</field>
            <field name="model">op.event.type</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Event Type">
                    <sheet>
                        <field name="active" invisible="1"/>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                                invisible="active == True"/>
                        <group>
                            <group>
                                <field name="name"/>
                            </group>
                        </group>
                        <div>
                            <label for="description" string="Description" class="mt32"/>
                            <field name="description" nolabel="1"/>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_op_event_type_search" model="ir.ui.view">
            <field name="name">op.event.type.search</field>
            <field name="model">op.event.type</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <search string="Event Types">
                    <field name="name"/>
                    <filter string="Archived" name="inactive"
                            domain="[('active', '=', False)]"/>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_open_op_event_type_view">
            <field name="name">Event Types</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">op.event.type</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_op_event_type_search"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_open_op_event_type_view_form">
            <field name="act_window_id" ref="act_open_op_event_type_view"/>
            <field name="sequence" eval="20"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_op_event_type_form"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_open_op_event_type_view_list">
            <field name="act_window_id" ref="act_open_op_event_type_view"/>
            <field name="sequence" eval="10"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_op_event_type_list"/>
        </record>
</odoo>
