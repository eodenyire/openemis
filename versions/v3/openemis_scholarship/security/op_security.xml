<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record model="ir.module.category" id="module_category_all_op_scholarship">
            <field name="name">Scholarship</field>
            <field name="description">Helps you manage student scholarship programs.</field>
            <field name="sequence">101</field>
            <field name="parent_id" eval="False"/>
        </record>

        <record id="module_category_openemis_scholarship" model="ir.module.category">
            <field name="name">Scholarship</field>
            <field name="description">Helps you manage student scholarship programs.</field>
            <field name="parent_id" ref="openemis_scholarship.module_category_all_op_scholarship"/>
            <field name="sequence">1</field>
        </record>

        <record id="group_scholarship_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_openemis_scholarship"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="implied_ids"
                   eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_scholarship_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_openemis_scholarship"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="implied_ids"
                   eval="[(4, ref('openemis_scholarship.group_scholarship_user'))]"/>
        </record>

        <record model="ir.rule" id="scholarship_user_rule">
            <field name="name">Scholarship User Rule</field>
            <field name="model_id" ref="model_op_scholarship"/>
            <field name="groups"
                   eval="[(4, ref('openemis_scholarship.group_scholarship_user'))]"/>
            <field name="domain_force">[('student_id.user_id', '=', user.id)]</field>
        </record>

        <record model="ir.rule" id="scholarship_manager_rule">
            <field name="name">Scholarship Manager Rule</field>
            <field name="model_id" ref="model_op_scholarship"/>
            <field name="groups"
                   eval="[(4, ref('openemis_scholarship.group_scholarship_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
</odoo>
