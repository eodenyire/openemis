<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Daily Menu Views -->
    <record id="view_op_daily_menu_list" model="ir.ui.view">
        <field name="name">op.daily.menu.list</field>
        <field name="model">op.daily.menu</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <list string="Daily Menus">
                <field name="name"/>
                <field name="date"/>
                <field name="meal_type"/>
                <field name="special_note" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_op_daily_menu_form" model="ir.ui.view">
        <field name="name">op.daily.menu.form</field>
        <field name="model">op.daily.menu</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <form string="Daily Menu">
                <header/>
                <sheet>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            invisible="active == True"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Menu Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="meal_type"/>
                        </group>
                    </group>
                    <label for="menu_item_ids" string="Menu Items" class="mt32"/>
                    <field name="menu_item_ids" nolabel="1">
                        <list string="Menu Items">
                            <field name="name"/>
                            <field name="food_category_id"/>
                            <field name="price"/>
                            <field name="is_vegetarian"/>
                            <field name="is_vegan"/>
                            <field name="calories" optional="hide"/>
                        </list>
                    </field>
                    <div>
                        <label for="special_note" string="Special Note" class="mt32"/>
                        <field name="special_note" nolabel="1"/>
                    </div>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_op_daily_menu_search" model="ir.ui.view">
        <field name="name">op.daily.menu.search</field>
        <field name="model">op.daily.menu</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <search string="Daily Menus">
                <field name="name"/>
                <field name="date"/>
                <field name="meal_type"/>
                <filter string="Breakfast" name="breakfast"
                        domain="[('meal_type', '=', 'breakfast')]"/>
                <filter string="Lunch" name="lunch"
                        domain="[('meal_type', '=', 'lunch')]"/>
                <filter string="Dinner" name="dinner"
                        domain="[('meal_type', '=', 'dinner')]"/>
                <filter string="Snack" name="snack"
                        domain="[('meal_type', '=', 'snack')]"/>
                <filter string="Archived" name="inactive"
                        domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Meal Type" name="group_meal_type"
                            context="{'group_by': 'meal_type'}"/>
                    <filter string="Date" name="group_date"
                            context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_op_daily_menu_calendar" model="ir.ui.view">
        <field name="name">op.daily.menu.calendar</field>
        <field name="model">op.daily.menu</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <calendar string="Daily Menus" date_start="date" color="meal_type">
                <field name="name"/>
                <field name="meal_type"/>
            </calendar>
        </field>
    </record>

    <record model="ir.actions.act_window" id="act_open_op_daily_menu_view">
        <field name="name">Daily Menus</field>
        <field name="path">cafeteria-daily-menus</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">op.daily.menu</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="search_view_id" ref="view_op_daily_menu_search"/>
    </record>

    <record model="ir.actions.act_window.view" id="act_op_daily_menu_view_form">
        <field name="act_window_id" ref="act_open_op_daily_menu_view"/>
        <field name="sequence" eval="30"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_op_daily_menu_form"/>
    </record>

    <record model="ir.actions.act_window.view" id="act_op_daily_menu_view_calendar">
        <field name="act_window_id" ref="act_open_op_daily_menu_view"/>
        <field name="sequence" eval="20"/>
        <field name="view_mode">calendar</field>
        <field name="view_id" ref="view_op_daily_menu_calendar"/>
    </record>

    <record model="ir.actions.act_window.view" id="act_op_daily_menu_view_list">
        <field name="act_window_id" ref="act_open_op_daily_menu_view"/>
        <field name="sequence" eval="10"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_op_daily_menu_list"/>
    </record>
</odoo>
