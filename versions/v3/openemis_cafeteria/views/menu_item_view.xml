<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Menu Item Views -->
    <record id="view_op_menu_item_list" model="ir.ui.view">
        <field name="name">op.menu.item.list</field>
        <field name="model">op.menu.item</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <list string="Menu Items">
                <field name="name"/>
                <field name="food_category_id"/>
                <field name="price"/>
                <field name="is_vegetarian" optional="hide"/>
                <field name="is_vegan" optional="hide"/>
                <field name="is_gluten_free" optional="hide"/>
                <field name="calories" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_op_menu_item_form" model="ir.ui.view">
        <field name="name">op.menu.item.form</field>
        <field name="model">op.menu.item</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <form string="Menu Item">
                <sheet>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            invisible="active == True"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Item Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="food_category_id"/>
                            <field name="price"/>
                            <field name="calories"/>
                        </group>
                        <group>
                            <field name="is_vegetarian"/>
                            <field name="is_vegan"/>
                            <field name="is_gluten_free"/>
                        </group>
                    </group>
                    <div>
                        <label for="description" string="Description" class="mt32"/>
                        <field name="description" nolabel="1"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_op_menu_item_search" model="ir.ui.view">
        <field name="name">op.menu.item.search</field>
        <field name="model">op.menu.item</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <search string="Menu Items">
                <field name="name"/>
                <field name="food_category_id"/>
                <filter string="Vegetarian" name="vegetarian"
                        domain="[('is_vegetarian', '=', True)]"/>
                <filter string="Vegan" name="vegan"
                        domain="[('is_vegan', '=', True)]"/>
                <filter string="Gluten Free" name="gluten_free"
                        domain="[('is_gluten_free', '=', True)]"/>
                <filter string="Archived" name="inactive"
                        domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Food Category" name="group_category"
                            context="{'group_by': 'food_category_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record model="ir.actions.act_window" id="act_open_op_menu_item_view">
        <field name="name">Menu Items</field>
        <field name="path">cafeteria-menu-items</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">op.menu.item</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_op_menu_item_search"/>
    </record>

    <record model="ir.actions.act_window.view" id="act_op_menu_item_view_form">
        <field name="act_window_id" ref="act_open_op_menu_item_view"/>
        <field name="sequence" eval="20"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_op_menu_item_form"/>
    </record>

    <record model="ir.actions.act_window.view" id="act_op_menu_item_view_list">
        <field name="act_window_id" ref="act_open_op_menu_item_view"/>
        <field name="sequence" eval="10"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_op_menu_item_list"/>
    </record>
</odoo>
