<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- System parameter placeholders for KUCCPS API -->
    <record id="param_kuccps_api_url" model="ir.config_parameter">
        <field name="key">digiguide.kuccps_api_url</field>
        <field name="value">https://api.kuccps.net/v1</field>
    </record>
    <record id="param_kuccps_api_key" model="ir.config_parameter">
        <field name="key">digiguide.kuccps_api_key</field>
        <field name="value"></field>
    </record>
</odoo>
