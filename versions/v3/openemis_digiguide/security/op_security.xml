<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record model="ir.module.category" id="module_category_digiguide">
        <field name="name">DigiGuide</field>
        <field name="description">Digital Career Guidance for CBC students.</field>
        <field name="sequence">120</field>
    </record>

    <record id="group_op_digiguide_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_digiguide"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <record id="group_op_digiguide_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_digiguide"/>
        <field name="implied_ids"
               eval="[(4, ref('base.group_user')),
                      (4, ref('openemis_digiguide.group_op_digiguide_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

</odoo>
