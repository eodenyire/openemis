<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.module.category" id="module_category_all_op_grading">
        <field name="name">Grading</field>
        <field name="description">Helps you manage letter grade scales and GPA configurations.</field>
        <field name="sequence">101</field>
        <field name="parent_id" eval="False"/>
    </record>

    <record id="module_category_openemis_grading" model="ir.module.category">
        <field name="name">Grading</field>
        <field name="description">Helps you manage letter grade scales and GPA configurations.</field>
        <field name="parent_id" ref="openemis_grading.module_category_all_op_grading"/>
        <field name="sequence">1</field>
    </record>

    <record id="group_grading_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_openemis_grading"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_grading_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_openemis_grading"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        <field name="implied_ids"
               eval="[(4, ref('openemis_grading.group_grading_user'))]"/>
    </record>
</odoo>
