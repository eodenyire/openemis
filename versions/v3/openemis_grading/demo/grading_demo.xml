<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="op_grading_config_demo" model="op.grading.config">
        <field name="name">Demo Grade Scale</field>
    </record>

    <record id="op_grading_rule_demo_a" model="op.grading.rule">
        <field name="name">A</field>
        <field name="min_marks">75.0</field>
        <field name="max_marks">100.0</field>
        <field name="gpa_point">4.0</field>
        <field name="description">Distinction</field>
        <field name="grading_config_id" ref="op_grading_config_demo"/>
    </record>

    <record id="op_grading_rule_demo_b" model="op.grading.rule">
        <field name="name">B</field>
        <field name="min_marks">60.0</field>
        <field name="max_marks">74.0</field>
        <field name="gpa_point">3.0</field>
        <field name="description">Merit</field>
        <field name="grading_config_id" ref="op_grading_config_demo"/>
    </record>

    <record id="op_grading_rule_demo_c" model="op.grading.rule">
        <field name="name">C</field>
        <field name="min_marks">50.0</field>
        <field name="max_marks">59.0</field>
        <field name="gpa_point">2.0</field>
        <field name="description">Pass</field>
        <field name="grading_config_id" ref="op_grading_config_demo"/>
    </record>

    <record id="op_grading_rule_demo_f" model="op.grading.rule">
        <field name="name">F</field>
        <field name="min_marks">0.0</field>
        <field name="max_marks">49.0</field>
        <field name="gpa_point">0.0</field>
        <field name="description">Fail</field>
        <field name="grading_config_id" ref="op_grading_config_demo"/>
    </record>
</odoo>
