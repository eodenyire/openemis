<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_op_grading_rule_list" model="ir.ui.view">
        <field name="name">op.grading.rule.list</field>
        <field name="model">op.grading.rule</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <list string="Grading Rules">
                <field name="name"/>
                <field name="grading_config_id"/>
                <field name="min_marks"/>
                <field name="max_marks"/>
                <field name="gpa_point"/>
                <field name="description" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_op_grading_rule_form" model="ir.ui.view">
        <field name="name">op.grading.rule.form</field>
        <field name="model">op.grading.rule</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <form string="Grading Rule">
                <sheet>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            invisible="active == True"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="grading_config_id"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name="min_marks"/>
                            <field name="max_marks"/>
                            <field name="gpa_point"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_op_grading_rule_search" model="ir.ui.view">
        <field name="name">op.grading.rule.search</field>
        <field name="model">op.grading.rule</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <search string="Grading Rules">
                <field name="name"/>
                <field name="grading_config_id"/>
                <filter string="Archived" name="inactive"
                        domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record model="ir.actions.act_window" id="act_open_op_grading_rule_view">
        <field name="name">Grading Rules</field>
        <field name="path">grading-rules</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">op.grading.rule</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_op_grading_rule_search"/>
    </record>

    <record model="ir.actions.act_window.view" id="act_open_op_grading_rule_view_form">
        <field name="act_window_id" ref="act_open_op_grading_rule_view"/>
        <field name="sequence" eval="20"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_op_grading_rule_form"/>
    </record>

    <record model="ir.actions.act_window.view" id="act_open_op_grading_rule_view_list">
        <field name="act_window_id" ref="act_open_op_grading_rule_view"/>
        <field name="sequence" eval="10"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_op_grading_rule_list"/>
    </record>
</odoo>
