<?xml version="1.0" encoding="UTF-8"?>
<odoo>
        <record id="view_op_alumni_list" model="ir.ui.view">
            <field name="name">op.alumni.list</field>
            <field name="model">op.alumni</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <list string="Alumni">
                    <field name="student_id"/>
                    <field name="graduation_year"/>
                    <field name="course_id"/>
                    <field name="batch_id" optional="hide"/>
                    <field name="employment_status"/>
                    <field name="employer_name" optional="hide"/>
                    <field name="job_title" optional="hide"/>
                    <field name="industry" optional="hide"/>
                    <field name="current_city" optional="hide"/>
                    <field name="current_country_id" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_op_alumni_form" model="ir.ui.view">
            <field name="name">op.alumni.form</field>
            <field name="model">op.alumni</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Alumni">
                    <header/>
                    <sheet>
                        <field name="active" invisible="1"/>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                                invisible="active == True"/>
                        <div class="oe_title">
                            <h1>
                                <field name="student_id" placeholder="Student"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Academic Information">
                                <field name="graduation_year"/>
                                <field name="course_id"/>
                                <field name="batch_id"/>
                            </group>
                            <group string="Location">
                                <field name="current_city"/>
                                <field name="current_country_id"/>
                            </group>
                        </group>
                        <group string="Career Information">
                            <group>
                                <field name="employment_status"/>
                                <field name="employer_name"/>
                                <field name="job_title"/>
                            </group>
                            <group>
                                <field name="industry"/>
                                <field name="linkedin_url"/>
                            </group>
                        </group>
                        <div>
                            <label for="notes" string="Notes" class="mt32"/>
                            <field name="notes" nolabel="1"/>
                        </div>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_op_alumni_kanban" model="ir.ui.view">
            <field name="name">op.alumni.kanban</field>
            <field name="model">op.alumni</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <kanban default_group_by="employment_status" class="o_kanban_small_column">
                    <field name="student_id"/>
                    <field name="graduation_year"/>
                    <field name="course_id"/>
                    <field name="employment_status"/>
                    <field name="employer_name"/>
                    <field name="job_title"/>
                    <field name="industry"/>
                    <field name="current_city"/>
                    <field name="active"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click">
                                <div class="o_kanban_record_top mb4">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="student_id"/>
                                        </strong>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div t-if="record.job_title.value">
                                        <i class="fa fa-briefcase mr-1" role="img" aria-label="Job Title"/>
                                        <field name="job_title"/>
                                    </div>
                                    <div t-if="record.employer_name.value">
                                        <i class="fa fa-building mr-1" role="img" aria-label="Employer"/>
                                        <field name="employer_name"/>
                                    </div>
                                    <div t-if="record.industry.value">
                                        <i class="fa fa-industry mr-1" role="img" aria-label="Industry"/>
                                        <field name="industry"/>
                                    </div>
                                    <div>
                                        <i class="fa fa-graduation-cap mr-1" role="img" aria-label="Graduation Year"/>
                                        <field name="graduation_year"/>
                                        <t t-if="record.course_id.value"> — <field name="course_id"/></t>
                                    </div>
                                    <div t-if="record.current_city.value">
                                        <i class="fa fa-map-marker mr-1" role="img" aria-label="Location"/>
                                        <field name="current_city"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="view_op_alumni_search" model="ir.ui.view">
            <field name="name">op.alumni.search</field>
            <field name="model">op.alumni</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <search string="Alumni">
                    <field name="student_id"/>
                    <field name="course_id"/>
                    <field name="batch_id"/>
                    <field name="graduation_year"/>
                    <field name="employer_name"/>
                    <field name="industry"/>
                    <field name="current_city"/>
                    <field name="current_country_id"/>
                    <separator/>
                    <filter string="Employed" name="employed"
                            domain="[('employment_status', '=', 'employed')]"/>
                    <filter string="Self Employed" name="self_employed"
                            domain="[('employment_status', '=', 'self_employed')]"/>
                    <filter string="Further Studies" name="further_studies"
                            domain="[('employment_status', '=', 'further_studies')]"/>
                    <filter string="Archived" name="inactive"
                            domain="[('active', '=', False)]"/>
                    <group expand="0" string="Group By">
                        <filter string="Employment Status" name="group_employment_status"
                                context="{'group_by': 'employment_status'}"/>
                        <filter string="Graduation Year" name="group_graduation_year"
                                context="{'group_by': 'graduation_year'}"/>
                        <filter string="Course" name="group_course"
                                context="{'group_by': 'course_id'}"/>
                        <filter string="Country" name="group_country"
                                context="{'group_by': 'current_country_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="view_op_alumni_graph" model="ir.ui.view">
            <field name="name">op.alumni.graph</field>
            <field name="model">op.alumni</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <graph string="Alumni" type="bar">
                    <field name="graduation_year" type="row"/>
                    <field name="course_id" type="col"/>
                </graph>
            </field>
        </record>

        <record id="view_op_alumni_pivot" model="ir.ui.view">
            <field name="name">op.alumni.pivot</field>
            <field name="model">op.alumni</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <pivot string="Alumni">
                    <field name="graduation_year" type="row"/>
                    <field name="course_id" type="col"/>
                </pivot>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_open_op_alumni_view">
            <field name="name">Alumni</field>
            <field name="path">alumni</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">op.alumni</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">list,kanban,form,graph,pivot</field>
            <field name="search_view_id" ref="view_op_alumni_search"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_open_op_alumni_view_list">
            <field name="act_window_id" ref="act_open_op_alumni_view"/>
            <field name="sequence" eval="10"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_op_alumni_list"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_open_op_alumni_view_kanban">
            <field name="act_window_id" ref="act_open_op_alumni_view"/>
            <field name="sequence" eval="20"/>
            <field name="view_mode">kanban</field>
            <field name="view_id" ref="view_op_alumni_kanban"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_open_op_alumni_view_form">
            <field name="act_window_id" ref="act_open_op_alumni_view"/>
            <field name="sequence" eval="30"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_op_alumni_form"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_open_op_alumni_view_graph">
            <field name="act_window_id" ref="act_open_op_alumni_view"/>
            <field name="sequence" eval="40"/>
            <field name="view_mode">graph</field>
            <field name="view_id" ref="view_op_alumni_graph"/>
        </record>

        <record model="ir.actions.act_window.view" id="act_open_op_alumni_view_pivot">
            <field name="act_window_id" ref="act_open_op_alumni_view"/>
            <field name="sequence" eval="50"/>
            <field name="view_mode">pivot</field>
            <field name="view_id" ref="view_op_alumni_pivot"/>
        </record>
</odoo>
