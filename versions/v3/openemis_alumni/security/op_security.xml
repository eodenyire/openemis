<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record model="ir.module.category" id="module_category_all_op_alumni">
            <field name="name">Alumni</field>
            <field name="description">Helps you manage your institute's alumni network.</field>
            <field name="sequence">105</field>
            <field name="parent_id" eval="False"/>
        </record>

        <record id="module_category_openemis_alumni" model="ir.module.category">
            <field name="name">Alumni</field>
            <field name="description">Helps you manage your institute's alumni network.</field>
            <field name="parent_id" ref="openemis_alumni.module_category_all_op_alumni"/>
            <field name="sequence">1</field>
        </record>

        <record id="group_alumni_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_openemis_alumni"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="implied_ids"
                   eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_alumni_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_openemis_alumni"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="implied_ids"
                   eval="[(4, ref('openemis_alumni.group_alumni_user'))]"/>
        </record>

        <!-- Alumni users can see all records (alumni networking) -->
        <record model="ir.rule" id="alumni_user_rule">
            <field name="name">Alumni User - All Records</field>
            <field name="model_id" ref="model_op_alumni"/>
            <field name="groups"
                   eval="[(4, ref('openemis_alumni.group_alumni_user'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Managers can read and edit all records -->
        <record model="ir.rule" id="alumni_manager_rule">
            <field name="name">Alumni Manager - All Records</field>
            <field name="model_id" ref="model_op_alumni"/>
            <field name="groups"
                   eval="[(4, ref('openemis_alumni.group_alumni_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
</odoo>
