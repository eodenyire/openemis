<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record model="ir.module.category" id="module_category_all_op_achievement">
            <field name="name">Achievement</field>
            <field name="description">Helps you manage your institute's student achievements and awards.</field>
            <field name="sequence">101</field>
            <field name="parent_id" eval="False"/>
        </record>
        <record id="module_category_openemis_achievement" model="ir.module.category">
            <field name="name">Achievement</field>
            <field name="description">Helps you manage your institute's student achievements and awards.</field>
            <field name="parent_id" ref="openemis_achievement.module_category_all_op_achievement"/>
            <field name="sequence">1</field>
        </record>

        <record id="group_achievement_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_openemis_achievement"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="implied_ids"
                   eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_achievement_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_openemis_achievement"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="implied_ids"
                   eval="[(4, ref('openemis_achievement.group_achievement_user'))]"/>
        </record>

        <record model="ir.rule" id="faculty_achievement_log_rule">
            <field name="name">Faculty Achievement Logs</field>
            <field name="model_id" ref="model_op_achievement"/>
            <field name="groups"
                   eval="[(4, ref('openemis_achievement.group_achievement_user'))]"/>
            <field name="domain_force">['|', ('faculty_id.user_id','=',user.id), ('faculty_id.user_id','in',user.child_ids.ids)]
            </field>
        </record>

        <record model="ir.rule" id="back_office_achievement_log_rule">
            <field name="name">Back Office Achievement Logs</field>
            <field name="model_id" ref="model_op_achievement"/>
            <field name="groups"
                   eval="[(4, ref('openemis_achievement.group_achievement_manager'))]"/>
            <field name="domain_force">[(1,'=',1)]</field>
        </record>
</odoo>
