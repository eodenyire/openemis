<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.module.category" id="module_category_all_op_transportation">
        <field name="name">Transportation</field>
        <field name="description">Helps you manage school transportation, routes and vehicles.</field>
        <field name="sequence">105</field>
        <field name="parent_id" eval="False"/>
    </record>

    <record id="module_category_openemis_transportation" model="ir.module.category">
        <field name="name">Transportation</field>
        <field name="description">Helps you manage school transportation, routes and vehicles.</field>
        <field name="parent_id" ref="openemis_transportation.module_category_all_op_transportation"/>
        <field name="sequence">1</field>
    </record>

    <record id="group_transportation_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_openemis_transportation"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_transportation_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_openemis_transportation"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        <field name="implied_ids"
               eval="[(4, ref('openemis_transportation.group_transportation_user'))]"/>
    </record>
</odoo>
