<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_op_transport_vehicle_list" model="ir.ui.view">
        <field name="name">op.transport.vehicle.list</field>
        <field name="model">op.transport.vehicle</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <list string="Vehicles">
                <field name="name"/>
                <field name="registration_number"/>
                <field name="vehicle_type"/>
                <field name="capacity"/>
                <field name="driver_name"/>
                <field name="driver_phone"/>
            </list>
        </field>
    </record>

    <record id="view_op_transport_vehicle_form" model="ir.ui.view">
        <field name="name">op.transport.vehicle.form</field>
        <field name="model">op.transport.vehicle</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <form string="Vehicle">
                <header/>
                <sheet>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            invisible="active == True"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="registration_number"/>
                            <field name="vehicle_type"/>
                            <field name="capacity"/>
                        </group>
                        <group>
                            <field name="driver_name"/>
                            <field name="driver_phone"/>
                            <field name="driver_license"/>
                        </group>
                    </group>
                    <div>
                        <label for="notes" string="Notes" class="mt32"/>
                        <field name="notes" nolabel="1"/>
                    </div>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_op_transport_vehicle_search" model="ir.ui.view">
        <field name="name">op.transport.vehicle.search</field>
        <field name="model">op.transport.vehicle</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <search string="Vehicles">
                <field name="name"/>
                <field name="registration_number"/>
                <field name="driver_name"/>
                <filter string="Bus" name="bus" domain="[('vehicle_type','=','bus')]"/>
                <filter string="Van" name="van" domain="[('vehicle_type','=','van')]"/>
                <filter string="Archived" name="inactive" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <record model="ir.actions.act_window" id="act_open_op_transport_vehicle_view">
        <field name="name">Vehicles</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">op.transport.vehicle</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_op_transport_vehicle_search"/>
    </record>

    <record model="ir.actions.act_window.view" id="act_op_transport_vehicle_view_form">
        <field name="act_window_id" ref="act_open_op_transport_vehicle_view"/>
        <field name="sequence" eval="20"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_op_transport_vehicle_form"/>
    </record>

    <record model="ir.actions.act_window.view" id="act_op_transport_vehicle_view_list">
        <field name="act_window_id" ref="act_open_op_transport_vehicle_view"/>
        <field name="sequence" eval="10"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_op_transport_vehicle_list"/>
    </record>
</odoo>
