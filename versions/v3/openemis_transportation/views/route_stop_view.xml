<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_op_transport_route_stop_list" model="ir.ui.view">
        <field name="name">op.transport.route.stop.list</field>
        <field name="model">op.transport.route.stop</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <list string="Route Stops">
                <field name="sequence" widget="handle"/>
                <field name="route_id"/>
                <field name="name"/>
                <field name="landmark"/>
                <field name="arrival_time"/>
            </list>
        </field>
    </record>

    <record id="view_op_transport_route_stop_form" model="ir.ui.view">
        <field name="name">op.transport.route.stop.form</field>
        <field name="model">op.transport.route.stop</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <form string="Route Stop">
                <sheet>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            invisible="active == True"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="route_id"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="landmark"/>
                            <field name="arrival_time"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_op_transport_route_stop_search" model="ir.ui.view">
        <field name="name">op.transport.route.stop.search</field>
        <field name="model">op.transport.route.stop</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <search string="Route Stops">
                <field name="name"/>
                <field name="route_id"/>
                <filter string="Archived" name="inactive" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <record model="ir.actions.act_window" id="act_open_op_transport_route_stop_view">
        <field name="name">Route Stops</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">op.transport.route.stop</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_op_transport_route_stop_search"/>
    </record>

    <record model="ir.actions.act_window.view" id="act_op_transport_route_stop_view_form">
        <field name="act_window_id" ref="act_open_op_transport_route_stop_view"/>
        <field name="sequence" eval="20"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_op_transport_route_stop_form"/>
    </record>

    <record model="ir.actions.act_window.view" id="act_op_transport_route_stop_view_list">
        <field name="act_window_id" ref="act_open_op_transport_route_stop_view"/>
        <field name="sequence" eval="10"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_op_transport_route_stop_list"/>
    </record>
</odoo>
