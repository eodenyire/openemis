<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_op_student_transport_list" model="ir.ui.view">
        <field name="name">op.student.transport.list</field>
        <field name="model">op.student.transport</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <list string="Student Transport">
                <field name="student_id"/>
                <field name="route_id"/>
                <field name="stop_id"/>
                <field name="transport_type"/>
                <field name="academic_year_id"/>
            </list>
        </field>
    </record>

    <record id="view_op_student_transport_form" model="ir.ui.view">
        <field name="name">op.student.transport.form</field>
        <field name="model">op.student.transport</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <form string="Student Transport">
                <header/>
                <sheet>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            invisible="active == True"/>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="route_id"/>
                            <field name="stop_id"/>
                        </group>
                        <group>
                            <field name="transport_type"/>
                            <field name="academic_year_id"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_op_student_transport_search" model="ir.ui.view">
        <field name="name">op.student.transport.search</field>
        <field name="model">op.student.transport</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <search string="Student Transport">
                <field name="student_id"/>
                <field name="route_id"/>
                <field name="academic_year_id"/>
                <filter string="Archived" name="inactive" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <record id="view_op_student_transport_pivot" model="ir.ui.view">
        <field name="name">op.student.transport.pivot</field>
        <field name="model">op.student.transport</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <pivot string="Student Transport Pivot">
                <field name="route_id" type="row"/>
                <field name="transport_type" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="view_op_student_transport_graph" model="ir.ui.view">
        <field name="name">op.student.transport.graph</field>
        <field name="model">op.student.transport</field>
        <field name="arch" type="xml">
            <graph string="Students per Route" type="bar">
                <field name="route_id"/>
                <field name="transport_type"/>
            </graph>
        </field>
    </record>

    <record model="ir.actions.act_window" id="act_open_op_student_transport_view">
        <field name="name">Student Transport</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">op.student.transport</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="search_view_id" ref="view_op_student_transport_search"/>
    </record>

    <record model="ir.actions.act_window.view" id="act_op_student_transport_view_form">
        <field name="act_window_id" ref="act_open_op_student_transport_view"/>
        <field name="sequence" eval="20"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_op_student_transport_form"/>
    </record>

    <record model="ir.actions.act_window.view" id="act_op_student_transport_view_list">
        <field name="act_window_id" ref="act_open_op_student_transport_view"/>
        <field name="sequence" eval="10"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_op_student_transport_list"/>
    </record>
</odoo>
