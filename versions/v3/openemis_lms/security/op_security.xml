<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.module.category" id="module_category_all_op_lms">
        <field name="name">LMS</field>
        <field name="description">Helps you manage online learning courses and student enrollment.</field>
        <field name="sequence">105</field>
        <field name="parent_id" eval="False"/>
    </record>

    <record id="module_category_openemis_lms" model="ir.module.category">
        <field name="name">LMS</field>
        <field name="description">Helps you manage online learning courses and student enrollment.</field>
        <field name="parent_id" ref="openemis_lms.module_category_all_op_lms"/>
        <field name="sequence">1</field>
    </record>

    <record id="group_lms_student" model="res.groups">
        <field name="name">Student</field>
        <field name="category_id" ref="module_category_openemis_lms"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_lms_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_openemis_lms"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_lms_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_openemis_lms"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        <field name="implied_ids" eval="[(4, ref('openemis_lms.group_lms_user'))]"/>
    </record>

    <!-- Record rules -->
    <record model="ir.rule" id="lms_course_faculty_rule">
        <field name="name">LMS Course - Faculty sees own courses</field>
        <field name="model_id" ref="model_op_lms_course"/>
        <field name="groups" eval="[(4, ref('openemis_lms.group_lms_user'))]"/>
        <field name="domain_force">[('faculty_id.user_id', '=', user.id)]</field>
    </record>

    <record model="ir.rule" id="lms_course_manager_rule">
        <field name="name">LMS Course - Manager sees all</field>
        <field name="model_id" ref="model_op_lms_course"/>
        <field name="groups" eval="[(4, ref('openemis_lms.group_lms_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record model="ir.rule" id="lms_course_student_rule">
        <field name="name">LMS Course - Student sees published courses</field>
        <field name="model_id" ref="model_op_lms_course"/>
        <field name="groups" eval="[(4, ref('openemis_lms.group_lms_student'))]"/>
        <field name="domain_force">[('state', '=', 'published')]</field>
    </record>

    <record model="ir.rule" id="lms_enrollment_student_rule">
        <field name="name">LMS Enrollment - Student sees own enrollments</field>
        <field name="model_id" ref="model_op_lms_enrollment"/>
        <field name="groups" eval="[(4, ref('openemis_lms.group_lms_student'))]"/>
        <field name="domain_force">[('student_id.user_id', '=', user.id)]</field>
    </record>

    <record model="ir.rule" id="lms_enrollment_faculty_rule">
        <field name="name">LMS Enrollment - Faculty sees enrollments for own courses</field>
        <field name="model_id" ref="model_op_lms_enrollment"/>
        <field name="groups" eval="[(4, ref('openemis_lms.group_lms_user'))]"/>
        <field name="domain_force">[('lms_course_id.faculty_id.user_id', '=', user.id)]</field>
    </record>

    <record model="ir.rule" id="lms_enrollment_manager_rule">
        <field name="name">LMS Enrollment - Manager sees all</field>
        <field name="model_id" ref="model_op_lms_enrollment"/>
        <field name="groups" eval="[(4, ref('openemis_lms.group_lms_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>
