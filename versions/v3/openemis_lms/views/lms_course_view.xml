<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- List View -->
    <record id="view_op_lms_course_list" model="ir.ui.view">
        <field name="name">op.lms.course.list</field>
        <field name="model">op.lms.course</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <list string="LMS Courses">
                <field name="name"/>
                <field name="code"/>
                <field name="faculty_id"/>
                <field name="course_id" optional="hide"/>
                <field name="subject_id" optional="hide"/>
                <field name="section_count"/>
                <field name="enrollment_count"/>
                <field name="state"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'published'"
                       decoration-muted="state == 'archived'"
                       widget="badge"/>
            </list>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_op_lms_course_kanban" model="ir.ui.view">
        <field name="name">op.lms.course.kanban</field>
        <field name="model">op.lms.course</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state">
                <field name="name"/>
                <field name="code"/>
                <field name="faculty_id"/>
                <field name="enrollment_count"/>
                <field name="state"/>
                <field name="image"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_image">
                            <img t-if="record.image.raw_value"
                                 t-att-src="kanban_image('op.lms.course', 'image', record.id.raw_value)"
                                 alt="Course Thumbnail" class="o_kanban_image_fill_left"/>
                            <img t-else=""
                                 src="/openemis_lms/static/description/icon.png"
                                 alt="LMS" class="o_kanban_image_fill_left"
                                 onerror="this.src='/web/static/img/placeholder.png'"/>
                        </div>
                        <div class="oe_kanban_details">
                            <strong class="o_kanban_record_title">
                                <field name="name"/>
                            </strong>
                            <div class="o_kanban_tags_section">
                                <span t-attf-class="badge rounded-pill
                                    #{record.state.raw_value == 'published' ? 'text-bg-success' :
                                      record.state.raw_value == 'archived' ? 'text-bg-secondary' :
                                      'text-bg-info'}">
                                    <field name="state"/>
                                </span>
                            </div>
                            <ul>
                                <li>
                                    Faculty: <field name="faculty_id"/>
                                </li>
                                <li>
                                    Enrollments: <field name="enrollment_count"/>
                                </li>
                            </ul>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_op_lms_course_form" model="ir.ui.view">
        <field name="name">op.lms.course.form</field>
        <field name="model">op.lms.course</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <form string="LMS Course">
                <header>
                    <button name="action_publish"
                            string="Publish"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_reset_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state not in ['published', 'archived']"/>
                    <button name="action_archive_course"
                            string="Archive"
                            type="object"
                            invisible="state != 'published'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,published,archived"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button"
                                name="open_lms_sections"
                                type="object"
                                icon="fa-list">
                            <field name="section_count" widget="statinfo"
                                   string="Sections"/>
                        </button>
                        <button class="oe_stat_button"
                                name="open_lms_enrollments"
                                type="object"
                                icon="fa-users">
                            <field name="enrollment_count" widget="statinfo"
                                   string="Enrollments"/>
                        </button>
                    </div>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            invisible="active == True"/>
                    <field name="image" widget="image"
                           class="oe_avatar" options="{'preview_image': 'image'}"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Course Name"/>
                        </h1>
                        <h2>
                            <field name="code" placeholder="Course Code"/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="faculty_id"/>
                            <field name="course_id"/>
                        </group>
                        <group>
                            <field name="subject_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" nolabel="1"/>
                        </page>
                        <page string="Sections">
                            <field name="section_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>
                        <page string="Enrollments">
                            <field name="enrollment_ids" nolabel="1">
                                <list>
                                    <field name="student_id"/>
                                    <field name="enrollment_date"/>
                                    <field name="completion_percentage"
                                           widget="progressbar"
                                           options="{'max_value': 100, 'editable': false}"/>
                                    <field name="status"
                                           decoration-info="status == 'enrolled'"
                                           decoration-warning="status == 'in_progress'"
                                           decoration-success="status == 'completed'"
                                           decoration-danger="status == 'dropped'"
                                           widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_op_lms_course_search" model="ir.ui.view">
        <field name="name">op.lms.course.search</field>
        <field name="model">op.lms.course</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <search string="LMS Courses">
                <field name="name"/>
                <field name="code"/>
                <field name="faculty_id"/>
                <field name="course_id"/>
                <field name="subject_id"/>
                <filter string="Draft" name="filter_draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Published" name="filter_published"
                        domain="[('state', '=', 'published')]"/>
                <filter string="Archived" name="filter_archived_state"
                        domain="[('state', '=', 'archived')]"/>
                <separator/>
                <filter string="Archived Records" name="inactive"
                        domain="[('active', '=', False)]"/>
                <newline/>
                <group expand="0" string="Group By...">
                    <filter string="Faculty" name="group_by_faculty"
                            domain="[]" context="{'group_by': 'faculty_id'}"/>
                    <filter string="State" name="group_by_state"
                            domain="[]" context="{'group_by': 'state'}"/>
                    <filter string="Course" name="group_by_course"
                            domain="[]" context="{'group_by': 'course_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record model="ir.actions.act_window" id="act_open_op_lms_course_view">
        <field name="name">LMS Courses</field>
        <field name="path">lms-courses</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">op.lms.course</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_op_lms_course_search"/>
    </record>

    <record model="ir.actions.act_window.view" id="act_open_op_lms_course_view_kanban">
        <field name="act_window_id" ref="act_open_op_lms_course_view"/>
        <field name="sequence" eval="10"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_op_lms_course_kanban"/>
    </record>

    <record model="ir.actions.act_window.view" id="act_open_op_lms_course_view_list">
        <field name="act_window_id" ref="act_open_op_lms_course_view"/>
        <field name="sequence" eval="20"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_op_lms_course_list"/>
    </record>

    <record model="ir.actions.act_window.view" id="act_open_op_lms_course_view_form">
        <field name="act_window_id" ref="act_open_op_lms_course_view"/>
        <field name="sequence" eval="30"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_op_lms_course_form"/>
    </record>
</odoo>
