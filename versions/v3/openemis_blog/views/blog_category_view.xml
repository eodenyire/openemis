<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Blog Category List View -->
    <record id="view_op_blog_category_list" model="ir.ui.view">
        <field name="name">op.blog.category.list</field>
        <field name="model">op.blog.category</field>
        <field name="arch" type="xml">
            <list string="Blog Categories">
                <field name="name"/>
                <field name="parent_id"/>
                <field name="post_count"/>
            </list>
        </field>
    </record>

    <!-- Blog Category Form View -->
    <record id="view_op_blog_category_form" model="ir.ui.view">
        <field name="name">op.blog.category.form</field>
        <field name="model">op.blog.category</field>
        <field name="arch" type="xml">
            <form string="Blog Category">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="parent_id"/>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1" colspan="2"/>
                    </group>
                    <group string="Sub-Categories">
                        <field name="child_ids" nolabel="1" colspan="2">
                            <list>
                                <field name="name"/>
                                <field name="post_count"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Window Action -->
    <record id="act_open_op_blog_category" model="ir.actions.act_window">
        <field name="name">Blog Categories</field>
        <field name="res_model">op.blog.category</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a blog category.
            </p>
        </field>
    </record>

</odoo>
