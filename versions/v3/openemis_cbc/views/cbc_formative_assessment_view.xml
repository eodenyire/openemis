<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cbc_fa_list" model="ir.ui.view">
        <field name="name">cbc.formative.assessment.list</field>
        <field name="model">cbc.formative.assessment</field>
        <field name="arch" type="xml">
            <list string="Formative Assessments" decoration-success="state == 'approved'"
                  decoration-info="state == 'confirmed'"
                  decoration-muted="state == 'draft'">
                <field name="date"/>
                <field name="name"/>
                <field name="student_id"/>
                <field name="grade_level"/>
                <field name="assessment_type"/>
                <field name="strand_id"/>
                <field name="performance_level"/>
                <field name="score"/>
                <field name="term"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_cbc_fa_form" model="ir.ui.view">
        <field name="name">cbc.formative.assessment.form</field>
        <field name="model">cbc.formative.assessment</field>
        <field name="arch" type="xml">
            <form string="Formative Assessment">
                <header>
                    <button name="action_confirm" string="Confirm"
                            type="object" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve"
                            type="object" class="oe_highlight"
                            invisible="state != 'confirmed'"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Assessment Title"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="assessment_type"/>
                            <field name="grade_level"/>
                            <field name="term"/>
                            <field name="academic_year_id"/>
                        </group>
                        <group>
                            <field name="student_id"/>
                            <field name="teacher_id"/>
                            <field name="subject_id"/>
                            <field name="outcome_id"/>
                            <field name="strand_id"/>
                        </group>
                    </group>
                    <group string="Performance">
                        <group>
                            <field name="performance_level"/>
                            <field name="score"/>
                            <field name="max_score"/>
                        </group>
                        <group>
                            <field name="portfolio_id"/>
                        </group>
                    </group>
                    <field name="observations" placeholder="Observations / Remarks…"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_cbc_fa_search" model="ir.ui.view">
        <field name="name">cbc.formative.assessment.search</field>
        <field name="model">cbc.formative.assessment</field>
        <field name="arch" type="xml">
            <search string="Formative Assessments">
                <field name="name"/>
                <field name="student_id"/>
                <field name="strand_id"/>
                <field name="grade_level"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                <group expand="0" string="Group By">
                    <filter string="Student" name="student"
                            context="{'group_by': 'student_id'}"/>
                    <filter string="Grade Level" name="grade_level"
                            context="{'group_by': 'grade_level'}"/>
                    <filter string="Term" name="term"
                            context="{'group_by': 'term'}"/>
                    <filter string="Strand" name="strand"
                            context="{'group_by': 'strand_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record model="ir.actions.act_window" id="act_cbc_fa_view">
        <field name="name">Formative Assessments</field>
        <field name="path">cbc-formative</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">cbc.formative.assessment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_cbc_fa_search"/>
    </record>
</odoo>
