<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cbc_strand_list" model="ir.ui.view">
        <field name="name">cbc.strand.list</field>
        <field name="model">cbc.strand</field>
        <field name="arch" type="xml">
            <list string="CBC Strands">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="grade_band"/>
                <field name="substrand_count" string="Sub-strands"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_cbc_strand_form" model="ir.ui.view">
        <field name="name">cbc.strand.form</field>
        <field name="model">cbc.strand</field>
        <field name="arch" type="xml">
            <form string="CBC Strand">
                <sheet>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            invisible="active == True"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Strand Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="grade_band"/>
                        </group>
                        <group>
                            <field name="subject_id"/>
                        </group>
                    </group>
                    <field name="description"/>
                    <notebook>
                        <page string="Sub-strands">
                            <field name="substrand_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="outcome_count" string="Outcomes"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_cbc_strand_search" model="ir.ui.view">
        <field name="name">cbc.strand.search</field>
        <field name="model">cbc.strand</field>
        <field name="arch" type="xml">
            <search string="CBC Strands">
                <field name="name"/>
                <field name="code"/>
                <filter string="Archived" name="inactive"
                        domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Grade Band" name="grade_band"
                            context="{'group_by': 'grade_band'}"/>
                </group>
            </search>
        </field>
    </record>

    <record model="ir.actions.act_window" id="act_cbc_strand_view">
        <field name="name">CBC Strands</field>
        <field name="path">cbc-strands</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">cbc.strand</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_cbc_strand_search"/>
    </record>
</odoo>
