<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.module.category" id="module_category_all_op_hostel">
        <field name="name">Hostel</field>
        <field name="description">Helps you manage hostel blocks, rooms and student accommodation.</field>
        <field name="sequence">105</field>
        <field name="parent_id" eval="False"/>
    </record>

    <record id="module_category_openemis_hostel" model="ir.module.category">
        <field name="name">Hostel</field>
        <field name="description">Helps you manage hostel blocks, rooms and student accommodation.</field>
        <field name="parent_id" ref="openemis_hostel.module_category_all_op_hostel"/>
        <field name="sequence">1</field>
    </record>

    <record id="group_hostel_user" model="res.groups">
        <field name="name">Faculty</field>
        <field name="category_id" ref="module_category_openemis_hostel"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_hostel_manager" model="res.groups">
        <field name="name">Admin</field>
        <field name="category_id" ref="module_category_openemis_hostel"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        <field name="implied_ids"
               eval="[(4, ref('openemis_hostel.group_hostel_user'))]"/>
    </record>
</odoo>
