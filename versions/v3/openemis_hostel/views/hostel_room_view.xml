<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_op_hostel_room_list" model="ir.ui.view">
        <field name="name">op.hostel.room.list</field>
        <field name="model">op.hostel.room</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <list string="Rooms">
                <field name="name"/>
                <field name="block_id"/>
                <field name="room_type_id"/>
                <field name="capacity"/>
                <field name="occupied"/>
                <field name="available"/>
                <field name="state"
                       widget="badge"
                       decoration-success="state == 'available'"
                       decoration-warning="state == 'partially_occupied'"
                       decoration-danger="state == 'fully_occupied'"
                       decoration-muted="state == 'maintenance'"
                       optional="show"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_op_hostel_room_form" model="ir.ui.view">
        <field name="name">op.hostel.room.form</field>
        <field name="model">op.hostel.room</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <form string="Room">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="available,partially_occupied,fully_occupied"/>
                </header>
                <sheet>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            invisible="active == True"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(openemis_hostel.act_open_op_hostel_allocation_view)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-bed"
                                context="{'default_room_id': id, 'search_default_room_id': id}">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="occupied"/>
                                </span>
                                <span class="o_stat_text">Occupied</span>
                            </div>
                        </button>
                        <button name="%(openemis_hostel.act_open_op_hostel_allocation_view)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-check-circle"
                                context="{'default_room_id': id, 'search_default_room_id': id}">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="available"/>
                                </span>
                                <span class="o_stat_text">Available</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Room Number"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="block_id"/>
                            <field name="room_type_id"/>
                        </group>
                        <group>
                            <field name="capacity"/>
                        </group>
                    </group>
                    <div>
                        <label for="description" string="Description" class="mt32"/>
                        <field name="description" nolabel="1"/>
                    </div>
                    <notebook>
                        <page string="Allocations" name="allocations">
                            <field name="allocation_ids" readonly="1">
                                <list>
                                    <field name="student_id"/>
                                    <field name="academic_year_id"/>
                                    <field name="check_in_date"/>
                                    <field name="check_out_date"/>
                                    <field name="monthly_fee"/>
                                    <field name="state"
                                           widget="badge"
                                           decoration-muted="state == 'draft'"
                                           decoration-success="state == 'confirmed'"
                                           decoration-info="state == 'checked_out'"
                                           decoration-danger="state == 'cancelled'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_op_hostel_room_kanban" model="ir.ui.view">
        <field name="name">op.hostel.room.kanban</field>
        <field name="model">op.hostel.room</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <kanban string="Rooms" class="o_kanban_small_column">
                <field name="name"/>
                <field name="block_id"/>
                <field name="room_type_id"/>
                <field name="capacity"/>
                <field name="occupied"/>
                <field name="available"/>
                <field name="state"/>
                <field name="active"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <div>
                                    <field name="state" widget="label_selection"
                                           options="{'classes': {
                                               'available': 'success',
                                               'partially_occupied': 'warning',
                                               'fully_occupied': 'danger',
                                               'maintenance': 'secondary'}}"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>
                                    <span class="text-muted">Block: </span>
                                    <field name="block_id"/>
                                </div>
                                <div>
                                    <span class="text-muted">Type: </span>
                                    <field name="room_type_id"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <span class="text-muted">Beds: </span>
                                    <field name="occupied"/>/<field name="capacity"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <span class="text-muted">Free: </span>
                                    <field name="available"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_op_hostel_room_search" model="ir.ui.view">
        <field name="name">op.hostel.room.search</field>
        <field name="model">op.hostel.room</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <search string="Rooms">
                <field name="name"/>
                <field name="block_id"/>
                <field name="room_type_id"/>
                <filter string="Available" name="available"
                        domain="[('state', '=', 'available')]"/>
                <filter string="Fully Occupied" name="fully_occupied"
                        domain="[('state', '=', 'fully_occupied')]"/>
                <filter string="Under Maintenance" name="maintenance"
                        domain="[('state', '=', 'maintenance')]"/>
                <filter string="Archived" name="inactive"
                        domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Block" name="group_block"
                            context="{'group_by': 'block_id'}"/>
                    <filter string="Room Type" name="group_room_type"
                            context="{'group_by': 'room_type_id'}"/>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record model="ir.actions.act_window" id="act_open_op_hostel_room_view">
        <field name="name">Rooms</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">op.hostel.room</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_op_hostel_room_search"/>
    </record>

    <record model="ir.actions.act_window.view" id="act_open_op_hostel_room_view_kanban">
        <field name="act_window_id" ref="act_open_op_hostel_room_view"/>
        <field name="sequence" eval="10"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_op_hostel_room_kanban"/>
    </record>

    <record model="ir.actions.act_window.view" id="act_open_op_hostel_room_view_list">
        <field name="act_window_id" ref="act_open_op_hostel_room_view"/>
        <field name="sequence" eval="20"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_op_hostel_room_list"/>
    </record>

    <record model="ir.actions.act_window.view" id="act_open_op_hostel_room_view_form">
        <field name="act_window_id" ref="act_open_op_hostel_room_view"/>
        <field name="sequence" eval="30"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_op_hostel_room_form"/>
    </record>
</odoo>
