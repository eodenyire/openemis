<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record model="ir.module.category" id="module_category_all_op_lesson">
            <field name="name">Lesson</field>
            <field name="description">Helps you manage faculty lesson plans.</field>
            <field name="sequence">101</field>
            <field name="parent_id" eval="False"/>
        </record>

        <record id="module_category_openemis_lesson" model="ir.module.category">
            <field name="name">Lesson</field>
            <field name="description">Helps you manage faculty lesson plans.</field>
            <field name="parent_id" ref="openemis_lesson.module_category_all_op_lesson"/>
            <field name="sequence">1</field>
        </record>

        <record id="group_lesson_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_openemis_lesson"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="implied_ids"
                   eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_lesson_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_openemis_lesson"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="implied_ids"
                   eval="[(4, ref('openemis_lesson.group_lesson_user'))]"/>
        </record>

        <!-- Faculty sees only their own lesson plans -->
        <record model="ir.rule" id="faculty_lesson_rule">
            <field name="name">Faculty Lesson Plans</field>
            <field name="model_id" ref="model_op_lesson"/>
            <field name="groups"
                   eval="[(4, ref('openemis_lesson.group_lesson_user'))]"/>
            <field name="domain_force">[('faculty_id.user_id', '=', user.id)]</field>
        </record>

        <!-- Managers see all lesson plans -->
        <record model="ir.rule" id="manager_lesson_rule">
            <field name="name">Manager Lesson Plans</field>
            <field name="model_id" ref="model_op_lesson"/>
            <field name="groups"
                   eval="[(4, ref('openemis_lesson.group_lesson_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
</odoo>
